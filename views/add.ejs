<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Student</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header class="navbar">
    <a href="/" class="brand">📚 Student Record System</a>
  </header>

  <main class="container">
    <div class="glass-panel student-form">
      <h1>Add New Student</h1>
      <form method="POST" action="/add">
        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="name" required placeholder="e.g. Jane Doe" />
        </div>
        <div class="form-group">
          <label>Email Address</label>
          <input type="email" name="email" required placeholder="e.g. jane@example.com" />
        </div>
        <div class="form-group">
          <label>Course</label>
          <input type="text" name="course" required placeholder="e.g. Computer Science" />
        </div>
        <div class="form-group">
          <label>Grade</label>
          <select name="grade">
            <option value="">Select a grade...</option>
            <option value="A">A</option>
            <option value="B">B</option>
            <option value="C">C</option>
            <option value="D">D</option>
            <option value="F">F</option>
          </select>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary" style="flex: 1;">Save Student</button>
          <a href="/" class="btn btn-outline" style="flex: 1; text-align: center;">Cancel</a>
        </div>
      </form>
    </div>
  </main>
</body>
</html>
