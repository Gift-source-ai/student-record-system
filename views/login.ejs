<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="auth-page">
  <header class="navbar">
    <a href="/" class="brand">📚 Student Record System</a>
  </header>

  <main class="container login-shell">
    <section class="auth-card glass-panel">
      <div class="auth-badge">🔐 Secure Portal</div>
      <h1 class="auth-title">Welcome back</h1>
      <p class="auth-subtitle">Sign in to manage student records with ease.</p>

      <form method="POST" action="/login" class="student-form">
        <div class="form-group">
          <label for="username">Username</label>
          <input id="username" type="text" name="username" required autocomplete="username" />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input id="password" type="password" name="password" required autocomplete="current-password" />
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Log In</button>
          <a href="/" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </section>
  </main>
</body>
</html>